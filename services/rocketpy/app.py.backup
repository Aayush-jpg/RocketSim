# ================================
# STARTUP/SHUTDOWN HANDLERS
# ================================

@app.on_event("startup")
async def startup_event():
    """Initialize application with startup time tracking"""
    global startup_time
    startup_time = time.time()
    
    logger.info("RocketPy Simulation Service starting up...")
    logger.info(f"RocketPy available: {ROCKETPY_AVAILABLE}")
    logger.info(f"Motor database loaded: {len(MOTOR_DATABASE)} motors")
    logger.info(f"Thread pool initialized with {executor._max_workers} workers")
    logger.info(f"Enhanced simulation circuit breaker initialized (threshold: {ENHANCED_FAILURE_THRESHOLD})")
    
    # Test basic functionality
    try:
        if ROCKETPY_AVAILABLE:
            logger.info("✅ RocketPy library loaded successfully")
        else:
            logger.warning("⚠️ RocketPy library not available - using fallback simulations only")
    except Exception as e:
        logger.error(f"❌ Startup test failed: {e}")

@app.on_event("shutdown")
async def shutdown_event():
    """Cleanup on shutdown"""
    logger.info("RocketPy Simulation Service shutting down...")
    executor.shutdown(wait=True)

