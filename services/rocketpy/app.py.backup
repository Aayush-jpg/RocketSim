class SimulationEnvironment:
    """Wrapper for RocketPy Environment with enhanced features"""
    
    def __init__(self, config: EnvironmentModel):
        if not ROCKETPY_AVAILABLE:
            self.env = None
            return
            
        self.config = config
        self.env = Environment(
            latitude=config.latitude,
            longitude=config.longitude,
            elevation=config.elevation
        )
        
        # Set date if provided
        if config.date:
            try:
                date_obj = datetime.fromisoformat(config.date.replace('Z', '+00:00'))
                self.env.set_date(date_obj, timezone=config.timezone or "UTC")
            except:
                logger.warning(f"Failed to parse date: {config.date}")
        
        # Set atmospheric model
        if config.atmosphericModel == "standard":
            self.env.set_atmospheric_model(type='standard_atmosphere')
        elif config.atmosphericModel == "forecast":
            try:
                self.env.set_atmospheric_model(type='Forecast', file='GFS')
            except:
                logger.warning("Failed to load GFS forecast, using standard atmosphere")
                self.env.set_atmospheric_model(type='standard_atmosphere')
        
        # Add wind if specified
        if config.windSpeed and config.windSpeed > 0:
            self._add_wind_profile(config.windSpeed, config.windDirection or 0)
    
    def _add_wind_profile(self, wind_speed: float, wind_direction: float):
        """Add wind profile to environment using proper RocketPy API"""
        if not self.env or wind_speed == 0:
            return
            
        try:
            # Convert wind speed and direction to U and V components
            wind_direction_rad = math.radians(wind_direction)
            wind_u = wind_speed * math.sin(wind_direction_rad)  # East component
            wind_v = wind_speed * math.cos(wind_direction_rad)  # North component
            
            # Use the correct RocketPy wind API - set wind velocity components directly
            self.env.wind_velocity_x = wind_u
            self.env.wind_velocity_y = wind_v
            
            logger.info(f"Applied wind profile: {wind_speed} m/s at {wind_direction}° (U={wind_u:.2f}, V={wind_v:.2f})")
            
        except Exception as e:
            logger.warning(f"Failed to set wind profile: {e}")
            # Store wind parameters for use in simplified calculations
            self.wind_speed = wind_speed
            self.wind_direction = wind_direction
    
    def _setup_enhanced_atmosphere(self, config: EnvironmentModel):
        """Setup enhanced atmospheric profile with better modeling"""
        if not self.env:
            return
            
        try:
            if config.atmosphericModel == "forecast" and config.date:
                # Use forecast data
                self.env.set_atmospheric_model(type='Forecast', file='GFS')
                logger.info("Set forecast atmospheric model")
            else:
                # Use standard atmosphere
                self.env.set_atmospheric_model(type='standard_atmosphere')
                logger.info("Set standard atmospheric model")
        except Exception as e:
            logger.warning(f"Failed to set enhanced atmospheric model: {e}")
            # Fallback to standard
            try:
                self.env.set_atmospheric_model(type='standard_atmosphere')
            except:
                pass
    
    def _setup_wind_profile(self, config: EnvironmentModel):
        """Setup wind profile for enhanced simulations"""
        if config.windSpeed and config.windSpeed > 0:
            self._add_wind_profile(config.windSpeed, config.windDirection or 0.0)
    
    def _setup_weather_forecast(self, config: EnvironmentModel):
        """Setup weather forecast data"""
        if config.atmosphericModel == "forecast" and config.date:
            try:
                # Set date for forecast
                date_obj = datetime.fromisoformat(config.date.replace('Z', '+00:00'))
                self.env.set_date(date_obj, timezone=config.timezone or "UTC")
                logger.info(f"Set forecast date: {config.date}")
            except Exception as e:
                logger.warning(f"Failed to set forecast date: {e}")
    
    def _setup_custom_atmosphere(self):
        """Setup custom atmospheric profile"""
        # Use standard atmosphere as the base
        try:
            # Just use the standard atmosphere - no need to set model type
            logger.info("Using standard atmospheric profile")
        except Exception as e:
            logger.warning(f"Failed to set atmospheric model: {e}")

class SimulationMotor:
    """Enhanced motor wrapper supporting multiple motor types"""
    
    def __init__(self, motor_id: str):
        self.motor_id = motor_id
        self.spec = MOTOR_DATABASE.get(motor_id, MOTOR_DATABASE["default-motor"])
        self.motor = None
        
        if not ROCKETPY_AVAILABLE:
            return
        
        self._create_motor()
    
    def _create_motor(self):
        """Create motor from specification - use file-based approach to avoid RocketPy errors"""
        try:
            # Create a simple thrust curve file that RocketPy can read reliably
            thrust_data = self._create_thrust_file()
            
            # Use the most basic motor creation possible
            if self.spec["type"] == "solid":
                self.motor = SolidMotor(
                    thrust_source=thrust_data,
                    dry_mass=self.spec["weight"]["total"] - self.spec["weight"]["propellant"],
                    dry_inertia=(0.1, 0.1, 0.001),  # Very simple inertia
                    nozzle_radius=0.01,  # Fixed small nozzle
                    grain_number=1,
                    grain_density=1800,
                    grain_outer_radius=0.02,
                    grain_initial_inner_radius=0.005,
                    grain_initial_height=0.1,
                    grain_separation=0.005,
                    grains_center_of_mass_position=0.5,
                    center_of_dry_mass_position=0.5,
                    nozzle_position=0,
                    burn_time=self.spec["burnTime"]
                )
            else:
                # For liquid and hybrid, always use GenericMotor
                self.motor = GenericMotor(
                    thrust_source=thrust_data,
                    burn_time=self.spec["burnTime"],
                    chamber_radius=0.02,
                    chamber_height=0.1,
                    chamber_position=0.5,
                    propellant_initial_mass=self.spec["weight"]["propellant"],
                    dry_mass=self.spec["weight"]["total"] - self.spec["weight"]["propellant"],
                    dry_inertia=(0.1, 0.1, 0.001),
                    nozzle_radius=0.01
                )
                
        except Exception as e:
            logger.error(f"Motor creation failed: {e}")
            # Create absolute minimal fallback motor
            self._create_minimal_motor()
    
    def _create_thrust_file(self) -> str:
        """Create a thrust curve file that RocketPy can read without errors"""
        import tempfile
        import os
        
        # Create very simple 3-point thrust curve
        burn_time = self.spec["burnTime"]
        avg_thrust = self.spec["avgThrust"]
        
        thrust_points = [
            (0.0, 0.0),
            (burn_time * 0.5, avg_thrust),
            (burn_time, 0.0)
        ]
        
        # Write to temporary file
        fd, filepath = tempfile.mkstemp(suffix='.eng', text=True)
        try:
            with os.fdopen(fd, 'w') as f:
                f.write(f"; Motor: {self.spec['id']}\n")
                f.write(f"{self.spec['dimensions']['diameter']} {self.spec['dimensions']['length']} 0 0 {self.spec['weight']['propellant']} {self.spec['weight']['total']} {self.spec['manufacturer']}\n")
                for time, thrust in thrust_points:
                    f.write(f"{time:.3f} {thrust:.3f}\n")
                f.write(";\n")
            return filepath
        except Exception as e:
            os.close(fd)
            os.unlink(filepath)
            raise e
    
    def _create_minimal_motor(self):
        """Create the most minimal motor possible to avoid all RocketPy errors"""
        try:
            # Use the simplest possible thrust curve - just 3 points
            simple_curve = [
                (0.0, 0.0),
                (self.spec["burnTime"] * 0.5, self.spec["avgThrust"]),
                (self.spec["burnTime"], 0.0)
            ]
            
            self.motor = GenericMotor(
                thrust_source=simple_curve,
                burn_time=self.spec["burnTime"],
                chamber_radius=0.02,  # Fixed 2cm radius
                chamber_height=0.1,   # Fixed 10cm height
                chamber_position=0.5,
                propellant_initial_mass=1.0,  # Fixed 1kg propellant
                dry_mass=0.5,  # Fixed 0.5kg dry mass
                dry_inertia=(0.1, 0.1, 0.001),  # Fixed simple inertia
                nozzle_radius=0.01  # Fixed 1cm nozzle
            )
        except Exception as e:
            logger.error(f"Even minimal motor creation failed: {e}")
            self.motor = None
    
    def _generate_simple_thrust_curve(self) -> List[Tuple[float, float]]:
        """Generate very simple thrust curve that won't cause RocketPy interpolation errors"""
        burn_time = self.spec["burnTime"]
        avg_thrust = self.spec["avgThrust"]
        
        # Create simple 4-point thrust curve that RocketPy can handle reliably
        curve = [
            (0.0, 0.0),                    # Start at zero
            (0.1, avg_thrust * 1.2),       # Quick ramp up
            (burn_time * 0.9, avg_thrust), # Sustained burn
            (burn_time, 0.0)               # End at zero
        ]
        
        return curve
    
    def _create_liquid_motor(self):
        """Create liquid motor with staged combustion"""
        thrust_curve = self._generate_simple_liquid_thrust_curve()
        
        # Always use GenericMotor for liquid engines as it's more reliable
        try:
            self.motor = GenericMotor(
                thrust_source=thrust_curve,
                burn_time=self.spec["burnTime"],
                chamber_radius=self.spec["dimensions"]["diameter"] / 2000,
                chamber_height=self.spec["dimensions"]["length"] / 1000,
                chamber_position=0.5,
                propellant_initial_mass=self.spec["weight"]["propellant"],
                dry_mass=self.spec["weight"]["total"] - self.spec["weight"]["propellant"],
                dry_inertia=(0.1, 0.1, 0.001),
                nozzle_radius=self.spec["dimensions"]["diameter"] / 2000
            )
        except Exception as e:
            logger.error(f"GenericMotor creation failed: {e}")
            raise
    
    def _create_hybrid_motor(self):
        """Create hybrid motor"""
        thrust_curve = self._generate_simple_hybrid_thrust_curve()
        
        # Always use GenericMotor for hybrid engines as it's more reliable
        try:
            self.motor = GenericMotor(
                thrust_source=thrust_curve,
                burn_time=self.spec["burnTime"],
                chamber_radius=self.spec["dimensions"]["diameter"] / 2000,
                chamber_height=self.spec["dimensions"]["length"] / 1000,
                chamber_position=0.5,
                propellant_initial_mass=self.spec["weight"]["propellant"],
                dry_mass=self.spec["weight"]["total"] - self.spec["weight"]["propellant"],
                dry_inertia=(0.1, 0.1, 0.001),
                nozzle_radius=self.spec["dimensions"]["diameter"] / 2000
            )
        except Exception as e:
            logger.error(f"GenericMotor creation failed: {e}")
            raise
    
    def _generate_simple_liquid_thrust_curve(self) -> List[Tuple[float, float]]:
        """Generate simple liquid engine thrust curve"""
        burn_time = self.spec["burnTime"]
        avg_thrust = self.spec["avgThrust"]
        
        # Simple 4-point curve for liquid engines
        curve = [
            (0.0, 0.0),                      # Start at zero
            (0.2, avg_thrust),               # Quick startup
            (burn_time * 0.95, avg_thrust),  # Steady burn
            (burn_time, 0.0)                 # Quick shutdown
        ]
        
        return curve
    
    def _generate_simple_hybrid_thrust_curve(self) -> List[Tuple[float, float]]:
        """Generate simple hybrid engine thrust curve"""
        burn_time = self.spec["burnTime"]
        avg_thrust = self.spec["avgThrust"]
        
        # Simple 4-point curve for hybrid engines
        curve = [
            (0.0, 0.0),                      # Start at zero
            (0.5, avg_thrust * 1.1),         # Gradual startup
            (burn_time * 0.9, avg_thrust),   # Steady burn with slight decay
            (burn_time, 0.0)                 # End at zero
        ]
        
        return curve
    
    def _generate_thrust_curve(self) -> List[Tuple[float, float]]:
        """Generate realistic thrust curve for solid motor"""
        burn_time = self.spec["burnTime"]
        avg_thrust = self.spec["avgThrust"]
        
        curve = []
        time_points = np.linspace(0, burn_time, 20)
        
        for t in time_points:
            normalized_time = t / burn_time
            
            if normalized_time < 0.1:
                # Initial spike
                thrust = avg_thrust * (1.5 + 0.5 * np.sin(normalized_time * 10))
            elif normalized_time < 0.8:
                # Sustained burn with variation
                thrust = avg_thrust * (1.0 + 0.1 * np.sin(normalized_time * 8))
            else:
                # Tail-off
                thrust = avg_thrust * (1.2 - (normalized_time - 0.8) / 0.2)
            
            curve.append((t, max(0, thrust)))
        
        curve.append((burn_time + 0.1, 0))
        return curve
    
    def _generate_liquid_thrust_curve(self) -> List[Tuple[float, float]]:
        """Generate liquid engine thrust curve"""
        burn_time = self.spec["burnTime"]
        avg_thrust = self.spec["avgThrust"]
        
        curve = []
        time_points = np.linspace(0, burn_time, 30)
        
        for t in time_points:
            normalized_time = t / burn_time
            
            if normalized_time < 0.05:
                # Startup transient
                thrust = avg_thrust * (normalized_time / 0.05) * 0.8
            elif normalized_time < 0.95:
                # Steady state with minor oscillations
                thrust = avg_thrust * (1.0 + 0.02 * np.sin(normalized_time * 20))
            else:
                # Shutdown
                thrust = avg_thrust * (1 - (normalized_time - 0.95) / 0.05)
            
            curve.append((t, max(0, thrust)))
        
        curve.append((burn_time + 0.1, 0))
        return curve
    
    def _generate_hybrid_thrust_curve(self) -> List[Tuple[float, float]]:
        """Generate hybrid engine thrust curve"""
        burn_time = self.spec["burnTime"]
        avg_thrust = self.spec["avgThrust"]
        
        curve = []
        time_points = np.linspace(0, burn_time, 25)
        
        for t in time_points:
            normalized_time = t / burn_time
            
            if normalized_time < 0.1:
                # Initial buildup
                thrust = avg_thrust * (0.7 + 0.3 * normalized_time / 0.1)
            elif normalized_time < 0.9:
                # Steady burn with regression effects
                thrust = avg_thrust * (1.0 - 0.1 * normalized_time + 0.05 * np.sin(normalized_time * 6))
            else:
                # Tail-off
                thrust = avg_thrust * (1.1 - (normalized_time - 0.9) / 0.1)
            
            curve.append((t, max(0, thrust)))
        
        curve.append((burn_time + 0.1, 0))
        return curve

class SimulationRocket:
    """Enhanced rocket wrapper with component modeling"""
    
    def __init__(self, rocket_config: RocketModel, motor: SimulationMotor):
        self.config = rocket_config
        self.motor = motor
        self.rocket = None
        
        if not ROCKETPY_AVAILABLE:
            return
        
        self._create_rocket()
    
    def _create_rocket(self):
        """Create RocketPy rocket from configuration"""
        # Calculate rocket properties from parts
        radius = self._calculate_radius()
        mass = self._calculate_dry_mass()
        inertia = self._calculate_inertia()
        com = self._calculate_center_of_mass()
        drag_curve = self._calculate_drag_curve()
        
        self.rocket = Rocket(
            radius=radius,
            mass=mass,
            inertia=inertia,
            power_off_drag=drag_curve,
            power_on_drag=drag_curve,
            center_of_mass_without_motor=com,
            coordinate_system_orientation="tail_to_nose"
        )
        
        # Add motor
        if self.motor.motor:
            motor_position = self._calculate_motor_position()
            self.rocket.add_motor(self.motor.motor, position=motor_position)
        
        # Add components
        self._add_nose_cone()
        self._add_fins()
        self._add_parachutes()
    
    def _calculate_radius(self) -> float:
        """Calculate rocket radius from body parts"""
        body_parts = [p for p in self.config.parts if p.type == "body"]
        if body_parts:
            # Convert diameter to radius and cm to m
            return body_parts[0].Ø / 200 if body_parts[0].Ø else 0.05
        return 0.05  # Default 5cm radius
    
    def _calculate_dry_mass(self) -> float:
        """Calculate dry mass from parts"""
        mass = 0.5  # Base mass
        
        for part in self.config.parts:
            if part.type == "nose":
                mass += 0.05 * (part.length or 15) / 10
            elif part.type == "body":
                mass += 0.1 * (part.length or 40) / 10 * (part.Ø or 5) / 5
            elif part.type == "fin":
                mass += 0.01 * (part.root or 8) * (part.span or 6) / 48
        
        return mass
    
    def _calculate_inertia(self) -> Tuple[float, float, float]:
        """Calculate rocket inertia tensor"""
        mass = self._calculate_dry_mass()
        radius = self._calculate_radius()
        length = self._calculate_total_length()
        
        # Simplified inertia calculation for cylinder
        ixx = iyy = mass * (3 * radius**2 + length**2) / 12
        izz = mass * radius**2 / 2
        
        return (ixx, iyy, izz)
    
    def _calculate_total_length(self) -> float:
        """Calculate total rocket length"""
        nose_length = sum(p.length or 15 for p in self.config.parts if p.type == "nose") / 100
        body_length = sum(p.length or 40 for p in self.config.parts if p.type == "body") / 100
        return nose_length + body_length
    
    def _calculate_center_of_mass(self) -> float:
        """Calculate center of mass without motor"""
        total_length = self._calculate_total_length()
        return total_length * 0.5  # Simplified: assume uniform mass distribution
    
    def _calculate_motor_position(self) -> float:
        """Calculate motor position in rocket"""
        return 0  # At the tail
    
    def _calculate_drag_curve(self) -> float:
        """Calculate drag coefficient"""
        return self.config.Cd
    
    def _add_nose_cone(self):
        """Add nose cone to rocket"""
        nose_parts = [p for p in self.config.parts if p.type == "nose"]
        if not nose_parts or not self.rocket:
            return
        
        nose = nose_parts[0]
        length = (nose.length or 15) / 100  # cm to m
        kind = nose.shape or "ogive"
        
        # Map our shapes to RocketPy shapes
        shape_map = {
            "ogive": "tangent ogive",
            "conical": "conical",
            "elliptical": "elliptical",
            "parabolic": "parabolic"
        }
        
        total_length = self._calculate_total_length()
        position = total_length - length  # Position from tail
        
        try:
            self.rocket.add_nose(
                length=length,
                kind=shape_map.get(kind, "tangent ogive"),
                position=position
            )
        except Exception as e:
            logger.warning(f"Failed to add nose cone: {e}")
    
    def _add_fins(self):
        """Add fins to rocket"""
        fin_parts = [p for p in self.config.parts if p.type == "fin"]
        if not fin_parts or not self.rocket:
            return
        
        fin = fin_parts[0]
        root_chord = (fin.root or 8) / 100  # cm to m
        tip_chord = (fin.tip or fin.root * 0.5 if fin.root else 4) / 100
        span = (fin.span or 6) / 100
        sweep_length = (fin.sweep or 2) / 100
        
        try:
            self.rocket.add_trapezoidal_fins(
                n=3,  # 3 fins
                root_chord=root_chord,
                tip_chord=tip_chord,
                span=span,
                position=0.1,  # Slightly above the tail
                cant_angle=0,
                sweep_length=sweep_length,
                airfoil=None
            )
        except Exception as e:
            logger.warning(f"Failed to add fins: {e}")
    
    def _add_parachutes(self):
        """Add parachutes to rocket"""
        parachute_parts = [p for p in self.config.parts if p.type == "parachute"]
        
        for i, chute in enumerate(parachute_parts):
            if not self.rocket:
                break
                
            cd_s = chute.cd_s or 1.0
            trigger_altitude = 500  # Default trigger altitude
            lag = chute.lag or 1.5
            
            try:
                self.rocket.add_parachute(
                    name=f"parachute_{i}",
                    cd_s=cd_s,
                    trigger=trigger_altitude,
                    sampling_rate=105,
                    lag=lag,
                    noise=(0, 8.3, 0.5)
                )
            except Exception as e:
                logger.warning(f"Failed to add parachute {i}: {e}")

class SimulationFlight:
    """Enhanced flight simulation wrapper"""
    
    def __init__(self, rocket: SimulationRocket, environment: SimulationEnvironment, 
                 launch_params: LaunchParametersModel):
        self.rocket = rocket
        self.environment = environment
        self.launch_params = launch_params
        self.flight = None
        self.results = None
        
        if not ROCKETPY_AVAILABLE or not rocket.rocket or not environment.env:
            return
        
        self._run_simulation()
    
    def _run_simulation(self):
        """Run the flight simulation with thread-safe integrator"""
        try:
            # Check if rocket and environment are valid before attempting simulation
            if not self.rocket.rocket or not self.environment.env:
                logger.error("Invalid rocket or environment for simulation")
                raise Exception("Invalid rocket or environment configuration")
            
            # Check if motor exists and has valid thrust data
            if not self.rocket.motor or not self.rocket.motor.motor:
                logger.error("Invalid motor configuration")
                raise Exception("Motor not properly configured")
            
            # Use global lock to prevent RocketPy integrator conflicts
            with rocketpy_lock:
                try:
                    # Use default integrator with global lock for thread safety
                    self.flight = Flight(
                        rocket=self.rocket.rocket,
                        environment=self.environment.env,
                        rail_length=self.launch_params.railLength,
                        inclination=self.launch_params.inclination,
                        heading=self.launch_params.heading,
                        rtol=1e-6,
                        atol=1e-9
                    )
                except Exception as motor_error:
                    logger.warning(f"Flight creation failed with motor error: {motor_error}")
                    # Try recreating with simplified motor
                    self._recreate_with_simplified_motor()
                    if self.rocket.rocket:
                        self.flight = Flight(
                            rocket=self.rocket.rocket,
                            environment=self.environment.env,
                            rail_length=self.launch_params.railLength,
                            inclination=self.launch_params.inclination,
                            heading=self.launch_params.heading,
                            rtol=1e-4,
                            atol=1e-6
                        )
                    else:
                        raise Exception("Failed to create rocket with simplified motor")
            
            self._extract_results()
            
        except Exception as e:
            logger.error(f"6-DOF simulation failed: {e}")
            # Try fallback with even more conservative settings
            try:
                with rocketpy_lock:
                    # Create completely new rocket with minimal motor
                    self._create_fallback_rocket()
                    if self.rocket.rocket:
                        self.flight = Flight(
                            rocket=self.rocket.rocket,
                            environment=self.environment.env,
                            rail_length=self.launch_params.railLength,
                            inclination=self.launch_params.inclination,
                            heading=self.launch_params.heading,
                            rtol=1e-4,
                            atol=1e-6
                        )
                        self._extract_results()
                        logger.info("Fallback rocket simulation successful")
                    else:
                        raise Exception("Fallback rocket creation failed")
            except Exception as e2:
                logger.error(f"Fallback simulation also failed: {e2}")
                # Create minimal result instead of failing
                self._create_minimal_result()
    
    def _recreate_with_simplified_motor(self):
        """Recreate rocket with a simplified motor to avoid RocketPy motor errors"""
        try:
            # Create a very basic motor using GenericMotor with minimal parameters
            motor_spec = MOTOR_DATABASE.get(self.rocket.config.motorId, MOTOR_DATABASE["default-motor"])
            
            # Create simple thrust curve that won't cause interpolation issues
            simple_thrust_curve = [
                (0.0, 0.0),
                (0.1, motor_spec["avgThrust"]),
                (motor_spec["burnTime"] * 0.9, motor_spec["avgThrust"]),
                (motor_spec["burnTime"], 0.0)
            ]
            
            # Create new simplified motor
            simplified_motor = GenericMotor(
                thrust_source=simple_thrust_curve,
                burn_time=motor_spec["burnTime"],
                chamber_radius=motor_spec["dimensions"]["diameter"] / 2000,
                chamber_height=motor_spec["dimensions"]["length"] / 1000,
                chamber_position=0.5,
                propellant_initial_mass=motor_spec["weight"]["propellant"],
                dry_mass=motor_spec["weight"]["total"] - motor_spec["weight"]["propellant"],
                dry_inertia=(0.1, 0.1, 0.001),
                nozzle_radius=motor_spec["dimensions"]["diameter"] / 2000
            )
            
            # Update motor in rocket
            self.rocket.motor.motor = simplified_motor
            
            # Re-add motor to rocket
            if self.rocket.rocket:
                # Clear existing motors
                self.rocket.rocket.motors = []
                # Add the simplified motor
                motor_position = self.rocket._calculate_motor_position()
                self.rocket.rocket.add_motor(simplified_motor, position=motor_position)
                
            logger.info("Successfully recreated rocket with simplified motor")
            
        except Exception as e:
            logger.error(f"Failed to recreate with simplified motor: {e}")
            # Clear the rocket so fallback can take over
            self.rocket.rocket = None
    
    def _create_fallback_rocket(self):
        """Create a completely minimal rocket for fallback simulation"""
        try:
            motor_spec = MOTOR_DATABASE.get(self.rocket.config.motorId, MOTOR_DATABASE["default-motor"])
            
            # Create minimal rocket with basic parameters
            self.rocket.rocket = Rocket(
                radius=0.05,  # 5cm radius
                mass=1.0,     # 1kg mass
                inertia=(0.1, 0.1, 0.001),
                power_off_drag=0.5,
                power_on_drag=0.5,
                center_of_mass_without_motor=0.5,
                coordinate_system_orientation="tail_to_nose"
            )
            
            # Create ultra-simple motor
            fallback_thrust_curve = [
                (0.0, 0.0),
                (1.0, 50.0),  # Simple constant thrust
                (3.0, 0.0)
            ]
            
            fallback_motor = GenericMotor(
                thrust_source=fallback_thrust_curve,
                burn_time=3.0,
                chamber_radius=0.025,
                chamber_height=0.1,
                chamber_position=0.5,
                propellant_initial_mass=0.1,
                dry_mass=0.05,
                dry_inertia=(0.01, 0.01, 0.001),
                nozzle_radius=0.01
            )
            
            # Add motor to rocket
            self.rocket.rocket.add_motor(fallback_motor, position=0.0)
            
            logger.info("Created fallback rocket successfully")
            
        except Exception as e:
            logger.error(f"Failed to create fallback rocket: {e}")
            self.rocket.rocket = None
    
    def _create_minimal_result(self):
        """Create a minimal simulation result when all else fails"""
        motor_spec = MOTOR_DATABASE.get(self.rocket.config.motorId, MOTOR_DATABASE["default-motor"])
        
        self.results = SimulationResult(
            maxAltitude=300.0,  # Reasonable default
            maxVelocity=60.0,
            maxAcceleration=30.0,
            apogeeTime=8.0,
            stabilityMargin=1.5,
            thrustCurve=[(0.0, 0.0), (motor_spec["burnTime"]/2, motor_spec["avgThrust"]), (motor_spec["burnTime"], 0.0)],
            simulationFidelity="minimal_fallback",
            trajectory=None,
            flightEvents=None,
            impactVelocity=15.0,
            driftDistance=50.0
        )
        
        logger.info("Created minimal simulation result as final fallback")
    
    def _extract_results(self):
        """Extract key results from flight simulation"""
        if not self.flight:
            return
        
        try:
            # Basic flight metrics
            max_altitude = float(self.flight.apogee - self.environment.config.elevation)
            max_velocity = float(self.flight.max_speed)
            max_acceleration = float(self.flight.max_acceleration)
            apogee_time = float(self.flight.apogee_time)
            
            # Stability margin
            try:
                stability_margin = float(self.rocket.rocket.static_margin(0))
            except:
                stability_margin = 1.5  # Default value
            
            # Trajectory data (6-DOF)
            trajectory = self._extract_trajectory()
            
            # Flight events
            events = self._extract_events()
            
            # Impact data
            impact_velocity = getattr(self.flight, 'impact_velocity', None)
            drift_distance = self._calculate_drift_distance()
            
            # Thrust curve - use safe extraction that doesn't access RocketPy motor attributes
            thrust_curve = self._extract_thrust_curve()
            
            self.results = SimulationResult(
                maxAltitude=max_altitude,
                maxVelocity=max_velocity,
                maxAcceleration=max_acceleration,
                apogeeTime=apogee_time,
                stabilityMargin=stability_margin,
                thrustCurve=thrust_curve,
                simulationFidelity="standard",
                trajectory=trajectory,
                flightEvents=events,
                impactVelocity=impact_velocity,
                driftDistance=drift_distance
            )
            
        except Exception as e:
            logger.error(f"Failed to extract results: {e}")
            # Create minimal fallback result
            self.results = SimulationResult(
                maxAltitude=1000.0,
                maxVelocity=100.0,
                maxAcceleration=50.0,
                apogeeTime=10.0,
                stabilityMargin=1.5,
                thrustCurve=[(0.0, 0.0), (2.5, 50.0), (5.0, 0.0)],
                simulationFidelity="fallback"
            )
    
    def _extract_trajectory(self) -> TrajectoryData:
        """Extract 6-DOF trajectory data"""
        if not self.flight:
            return None
        
        try:
            time_points = self.flight.time
            
            # Position data
            x_data = self.flight.x
            y_data = self.flight.y
            z_data = self.flight.z
            position = [[float(x), float(y), float(z)] for x, y, z in zip(x_data, y_data, z_data)]
            
            # Velocity data
            vx_data = self.flight.vx
            vy_data = self.flight.vy
            vz_data = self.flight.vz
            velocity = [[float(vx), float(vy), float(vz)] for vx, vy, vz in zip(vx_data, vy_data, vz_data)]
            
            # Acceleration data
            ax_data = self.flight.ax
            ay_data = self.flight.ay
            az_data = self.flight.az
            acceleration = [[float(ax), float(ay), float(az)] for ax, ay, az in zip(ax_data, ay_data, az_data)]
            
            # Attitude quaternions (if available)
            attitude = None
            angular_velocity = None
            
            try:
                e0_data = self.flight.e0
                e1_data = self.flight.e1
                e2_data = self.flight.e2
                e3_data = self.flight.e3
                attitude = [[float(e0), float(e1), float(e2), float(e3)] 
                           for e0, e1, e2, e3 in zip(e0_data, e1_data, e2_data, e3_data)]
                
                wx_data = self.flight.wx
                wy_data = self.flight.wy
                wz_data = self.flight.wz
                angular_velocity = [[float(wx), float(wy), float(wz)] 
                                   for wx, wy, wz in zip(wx_data, wy_data, wz_data)]
            except:
                pass  # 6-DOF data not available
            
            return TrajectoryData(
                time=[float(t) for t in time_points],
                position=position,
                velocity=velocity,
                acceleration=acceleration,
                attitude=attitude,
                angularVelocity=angular_velocity
            )
            
        except Exception as e:
            logger.warning(f"Failed to extract trajectory: {e}")
            return None
    
    def _extract_events(self) -> List[FlightEvent]:
        """Extract flight events"""
        if not self.flight:
            return []
        
        events = []
        
        try:
            # Motor burnout
            if hasattr(self.flight, 'motor_burn_out_time'):
                events.append(FlightEvent(
                    name="Motor Burnout",
                    time=float(self.flight.motor_burn_out_time),
                    altitude=float(self.flight.z(self.flight.motor_burn_out_time))
                ))
            
            # Apogee
            events.append(FlightEvent(
                name="Apogee",
                time=float(self.flight.apogee_time),
                altitude=float(self.flight.apogee)
            ))
            
            # Parachute deployment
            for parachute in self.rocket.rocket.parachutes:
                if hasattr(parachute, 'triggering_event'):
                    events.append(FlightEvent(
                        name=f"Parachute Deployment ({parachute.name})",
                        time=float(parachute.triggering_event.t),
                        altitude=float(parachute.triggering_event.altitude)
                    ))
            
            # Impact
            if hasattr(self.flight, 'impact_time'):
                events.append(FlightEvent(
                    name="Impact",
                    time=float(self.flight.impact_time),
                    altitude=float(self.environment.config.elevation)
                ))
                
        except Exception as e:
            logger.warning(f"Failed to extract events: {e}")
        
        return events
    
    def _extract_thrust_curve(self) -> List[Tuple[float, float]]:
        """Extract motor thrust curve with bulletproof error handling"""
        # Always return fallback thrust curve based on motor database to avoid RocketPy attribute errors
        try:
            motor_spec = MOTOR_DATABASE.get(self.rocket.config.motorId, MOTOR_DATABASE["default-motor"])
            burn_time = motor_spec["burnTime"]
            avg_thrust = motor_spec["avgThrust"]
            
            # Generate realistic thrust curve from motor specs
            time_points = np.linspace(0, burn_time, 20)
            thrust_data = []
            
            for t in time_points:
                normalized_time = t / burn_time
                
                if normalized_time < 0.1:
                    # Initial spike
                    thrust = avg_thrust * (1.5 + 0.5 * np.sin(normalized_time * 10))
                elif normalized_time < 0.8:
                    # Sustained burn with variation
                    thrust = avg_thrust * (1.0 + 0.1 * np.sin(normalized_time * 8))
                else:
                    # Tail-off
                    thrust = avg_thrust * (1.2 - (normalized_time - 0.8) / 0.2)
                
                thrust_data.append((float(t), max(0.0, float(thrust))))
            
            thrust_data.append((burn_time + 0.1, 0.0))
            return thrust_data
            
        except Exception as e:
            logger.warning(f"Failed to generate thrust curve: {e}")
            # Ultimate fallback
            return [
                (0.0, 0.0),
                (0.1, 50.0),
                (2.0, 40.0),
                (2.5, 0.0)
            ]
    
    def _calculate_drift_distance(self) -> float:
        """Calculate drift distance from launch point"""
        if not self.flight:
            return 0.0
        
        try:
            # Safely extract impact coordinates
            impact_x = getattr(self.flight, 'x_impact', 0.0)
            impact_y = getattr(self.flight, 'y_impact', 0.0)
            
            # Handle numpy arrays and scalars safely
            if hasattr(impact_x, '__len__') and len(impact_x) > 0:
                impact_x = float(impact_x[0])
            elif hasattr(impact_x, 'item'):
                impact_x = float(impact_x.item())
            else:
                impact_x = float(impact_x)
                
            if hasattr(impact_y, '__len__') and len(impact_y) > 0:
                impact_y = float(impact_y[0])
            elif hasattr(impact_y, 'item'):
                impact_y = float(impact_y.item())
            else:
                impact_y = float(impact_y)
            
            return float(np.sqrt(impact_x**2 + impact_y**2))
        except Exception as e:
            logger.warning(f"Failed to calculate drift distance: {e}")
            return 0.0

# ================================
# MONTE CARLO SIMULATION
# ================================

class MonteCarloSimulation:
    """High-performance Monte Carlo simulation with threading and progress tracking"""
    
    def __init__(self, base_request: MonteCarloRequest):
        self.base_request = base_request
        self.results = []
        self.statistics = {}
        self.simulation_id = f"mc_{int(time.time() * 1000)}"
        
        # Initialize progress tracking
        with progress_lock:
            monte_carlo_progress[self.simulation_id] = {
                'completed': 0,
                'total': base_request.iterations,
                'successful': 0,
                'failed': 0,
                'start_time': time.time(),
                'status': 'initializing'
            }
    
    async def run(self) -> MonteCarloResult:
        """Run high-performance threaded Monte Carlo simulation"""
        logger.info(f"Starting threaded Monte Carlo simulation {self.simulation_id} with {self.base_request.iterations} iterations")
        
        try:
            # Update progress
            with progress_lock:
                monte_carlo_progress[self.simulation_id]['status'] = 'running_nominal'
        
            # Run nominal simulation first
            nominal_result = await self._run_nominal_simulation()
            
            # Update progress
            with progress_lock:
                monte_carlo_progress[self.simulation_id]['status'] = 'running_variations'
            
            # Run varied simulations in parallel using ThreadPoolExecutor
            await self._run_threaded_simulations()
            
            # Update progress
            with progress_lock:
                monte_carlo_progress[self.simulation_id]['status'] = 'calculating_statistics'
            
            # Calculate statistics from successful results
            self._calculate_statistics()
        
            # Calculate landing dispersion
            dispersion = self._calculate_landing_dispersion()
            
            # Update final progress
            with progress_lock:
                monte_carlo_progress[self.simulation_id]['status'] = 'completed'
                monte_carlo_progress[self.simulation_id]['end_time'] = time.time()
            
            successful_count = len([r for r in self.results if r.simulationFidelity != "failed"])
            logger.info(f"Monte Carlo simulation {self.simulation_id} completed: {successful_count}/{self.base_request.iterations} successful")
        
            return MonteCarloResult(
                nominal=nominal_result,
                statistics=self.statistics,
                iterations=[self._extract_summary(r) for r in self.results],
                landingDispersion=dispersion
            )
    
        except Exception as e:
            logger.error(f"Monte Carlo simulation {self.simulation_id} failed: {e}")
            with progress_lock:
                monte_carlo_progress[self.simulation_id]['status'] = 'failed'
                monte_carlo_progress[self.simulation_id]['error'] = str(e)
            raise
        finally:
            # Clean up progress tracking after some time
            asyncio.create_task(self._cleanup_progress_tracking())
    
    async def _run_nominal_simulation(self) -> SimulationResult:
        """Run nominal simulation with error handling"""
        try:
            return await self._run_single_simulation(
                self.base_request.rocket, 
                self.base_request.environment,
                self.base_request.launchParameters
            )
        except Exception as e:
            logger.error(f"Nominal simulation failed: {e}")
            # Use fallback values
            return SimulationResult(
                maxAltitude=1000.0,
                maxVelocity=100.0,
                maxAcceleration=50.0,
                apogeeTime=10.0,
                stabilityMargin=1.5,
                simulationFidelity="fallback"
            )
    
    async def _run_threaded_simulations(self):
        """Run Monte Carlo iterations in parallel using threading"""
        # Prepare all simulation configurations
        simulation_configs = []
        for i in range(self.base_request.iterations):
            try:
                varied_config = self._apply_variations(i)
                simulation_configs.append((i, varied_config))
            except Exception as e:
                logger.warning(f"Failed to prepare iteration {i}: {e}")
                simulation_configs.append((i, None))
        
        # Run simulations in parallel batches to avoid overwhelming the system
        batch_size = min(8, self.base_request.iterations)  # Process in batches of 8
        self.results = [None] * self.base_request.iterations  # Pre-allocate results list
        
        for batch_start in range(0, len(simulation_configs), batch_size):
            batch_end = min(batch_start + batch_size, len(simulation_configs))
            batch_configs = simulation_configs[batch_start:batch_end]
            
            # Submit batch to thread pool
            loop = asyncio.get_event_loop()
            futures = []
            
            for iteration_idx, config in batch_configs:
                if config is None:
                    # Handle failed configuration preparation
                    future = loop.run_in_executor(
                        executor, 
                        self._create_failed_result
                    )
                else:
                    # Run actual simulation
                    future = loop.run_in_executor(
                        executor, 
                        self._run_simulation_sync_wrapper, 
                        iteration_idx, 
                        *config
                    )
                futures.append((iteration_idx, future))
            
            # Wait for batch completion with progress updates
            for iteration_idx, future in futures:
                try:
                    result = await asyncio.wait_for(future, timeout=15.0)  # 15 second timeout per simulation
                    self.results[iteration_idx] = result
                    
                    # Update progress
                    with progress_lock:
                        progress = monte_carlo_progress[self.simulation_id]
                        progress['completed'] += 1
                        if result.simulationFidelity != "failed":
                            progress['successful'] += 1
                        else:
                            progress['failed'] += 1
                        
                        # Log progress every 10 iterations
                        if progress['completed'] % 10 == 0:
                            logger.info(f"Monte Carlo {self.simulation_id}: {progress['completed']}/{progress['total']} completed ({progress['successful']} successful)")
                
                except asyncio.TimeoutError:
                    logger.warning(f"Iteration {iteration_idx} timed out")
                    self.results[iteration_idx] = self._create_failed_result()
                    with progress_lock:
                        progress = monte_carlo_progress[self.simulation_id]
                        progress['completed'] += 1
                        progress['failed'] += 1
                    
                except Exception as e:
                    logger.warning(f"Iteration {iteration_idx} failed: {e}")
                    self.results[iteration_idx] = self._create_failed_result()
                    with progress_lock:
                        progress = monte_carlo_progress[self.simulation_id]
                        progress['completed'] += 1
                        progress['failed'] += 1
    
    def _run_simulation_sync_wrapper(self, iteration_idx: int, rocket: RocketModel, 
                                   environment: EnvironmentModel, launch_params: LaunchParametersModel) -> SimulationResult:
        """Synchronous wrapper for running simulations in thread pool"""
        try:
            # Use simplified fallback for speed in Monte Carlo
            return self._run_simplified_simulation_sync(rocket, environment, launch_params)
        except Exception as e:
            logger.warning(f"Iteration {iteration_idx} simulation failed: {e}")
            return self._create_failed_result()
    
    def _run_simplified_simulation_sync(self, rocket: RocketModel, environment: EnvironmentModel, 
                                      launch_params: LaunchParametersModel) -> SimulationResult:
        """Fast simplified simulation for Monte Carlo iterations"""
        # Use the simplified fallback physics for speed
        motor_spec = MOTOR_DATABASE.get(rocket.motorId, MOTOR_DATABASE["default-motor"])
        
        # Calculate basic rocket properties with variations
        dry_mass = 0.5  # Base mass
        for part in rocket.parts:
            if part.type == "body":
                dry_mass += 0.1 * (part.length or 40) / 40
            elif part.type == "nose":
                dry_mass += 0.05 * (part.length or 15) / 15
            elif part.type == "fin":
                dry_mass += 0.01 * (part.root or 8) * (part.span or 6) / 48
        
        total_mass = dry_mass + motor_spec["weight"]["propellant"]
        
        # Apply environmental variations
        wind_speed = environment.windSpeed or 0.0
        gravity = 9.81
        
        # Apply launch parameter variations
        inclination_rad = np.radians(launch_params.inclination)
        
        # Basic physics calculation with variations
        thrust = motor_spec["avgThrust"]
        burn_time = motor_spec["burnTime"]
        isp = motor_spec.get("isp", 200)
        
        # Apply drag coefficient variation
        drag_coefficient = rocket.Cd
        
        # Rocket equation with environmental effects
        exhaust_velocity = isp * gravity
        mass_ratio = total_mass / dry_mass
        delta_v = exhaust_velocity * np.log(mass_ratio)
        
        # Account for gravity loss (varies with inclination)
        gravity_loss = gravity * burn_time * np.cos(inclination_rad)
        effective_delta_v = delta_v - gravity_loss
        
        # Account for wind effects on trajectory
        wind_effect = 1.0 - (wind_speed * 0.02)  # Reduce performance with wind
        effective_delta_v *= wind_effect
        
        # Simple trajectory estimation with variations
        max_velocity = effective_delta_v * 0.8  # Account for losses
        
        # Account for drag variation
        drag_loss_factor = 1.0 - (drag_coefficient - 0.5) * 0.3  # Baseline Cd = 0.5
        max_velocity *= drag_loss_factor
        
        # Calculate altitude with atmospheric effects
        max_altitude = (max_velocity ** 2) / (2 * gravity) * 0.7  # Air resistance
        
        # Apply inclination effects to final altitude
        altitude_factor = np.sin(inclination_rad) ** 1.5  # Non-linear effect
        max_altitude *= altitude_factor
        
        # Calculate time to apogee
        apogee_time = max_velocity / gravity + burn_time * 0.3
        
        # Calculate stability with fin effects
        fin_count = len([p for p in rocket.parts if p.type == "fin"])
        fin_area = sum((p.root or 8) * (p.span or 6) for p in rocket.parts if p.type == "fin") / 10000  # cm² to m²
        stability_margin = 1.0 + fin_count * 0.3 + fin_area * 0.5
        
        # Add some realistic noise to prevent identical results
        thread_id = threading.get_ident()
        np.random.seed((int(time.time() * 1000000) + thread_id) % 2**32)  # Thread-safe seeding
        
        altitude_noise = np.random.normal(1.0, 0.05)  # ±5% variation
        velocity_noise = np.random.normal(1.0, 0.04)  # ±4% variation
        time_noise = np.random.normal(1.0, 0.03)      # ±3% variation
        
        max_altitude *= altitude_noise
        max_velocity *= velocity_noise
        apogee_time *= time_noise
        
        # Calculate drift distance with wind
        drift_distance = wind_speed * apogee_time * 2.0  # Simplified drift calculation
        
        return SimulationResult(
            maxAltitude=float(max(0, max_altitude)),
            maxVelocity=float(max(0, max_velocity)),
            maxAcceleration=float(thrust / total_mass),
            apogeeTime=float(max(0, apogee_time)),
            stabilityMargin=float(stability_margin),
            simulationFidelity="simplified_fast",
            driftDistance=float(drift_distance)
        )
    
    def _create_failed_result(self) -> SimulationResult:
        """Create a failed simulation result"""
        return SimulationResult(
                maxAltitude=0.0,
                maxVelocity=0.0,
                maxAcceleration=0.0,
                apogeeTime=0.0,
                stabilityMargin=0.0,
                simulationFidelity="failed"
            )
    
    async def _run_single_simulation(self, rocket: RocketModel, environment: EnvironmentModel, 
                                   launch_params: LaunchParametersModel) -> SimulationResult:
        """Run a single simulation iteration"""
        try:
            # Use the simplified fallback for speed in Monte Carlo
            return await simulate_simplified_fallback(rocket, environment, launch_params)
        except Exception as e:
            logger.warning(f"Single simulation failed: {e}")
            return self._create_failed_result()
    
    def _apply_variations(self, iteration: int) -> Tuple[RocketModel, EnvironmentModel, LaunchParametersModel]:
        """Apply parameter variations for a specific iteration"""
        import random
        import copy
        
        # Set seed for reproducible variations
        random.seed(iteration + 42)  # Add offset to avoid seed 0
        
        # Deep copy base configurations
        varied_rocket = copy.deepcopy(self.base_request.rocket)
        varied_environment = copy.deepcopy(self.base_request.environment or EnvironmentModel())
        varied_launch = copy.deepcopy(self.base_request.launchParameters or LaunchParametersModel())
        
        # Apply each variation
        for variation in self.base_request.variations:
            try:
                # Generate random value based on distribution
                if variation.distribution == "normal":
                    mean, std = variation.parameters[:2]
                    value = random.normalvariate(mean, std)
                elif variation.distribution == "uniform":
                    min_val, max_val = variation.parameters[:2]
                    value = random.uniform(min_val, max_val)
                elif variation.distribution == "triangular":
                    low, high = variation.parameters[:2]
                    mode = variation.parameters[2] if len(variation.parameters) > 2 else (low + high) / 2
                    value = random.triangular(low, high, mode)
                else:
                    continue
                
                # Apply variation to the appropriate parameter
                self._set_parameter_value(variation.parameter, value, varied_rocket, varied_environment, varied_launch)
                
            except Exception as e:
                logger.warning(f"Failed to apply variation {variation.parameter}: {e}")
                continue
        
        return varied_rocket, varied_environment, varied_launch
    
    def _set_parameter_value(self, parameter_path: str, value: float, 
                           rocket: RocketModel, environment: EnvironmentModel, launch: LaunchParametersModel):
        """Set a parameter value using dot notation path"""
        parts = parameter_path.split('.')
        
        if parts[0] == "rocket":
            if parts[1] == "Cd":
                rocket.Cd = max(0.1, min(2.0, value))  # Clamp Cd between 0.1 and 2.0
        elif parts[0] == "environment":
            if parts[1] == "windSpeed":
                environment.windSpeed = max(0.0, min(50.0, value))  # Clamp wind speed
            elif parts[1] == "windDirection":
                environment.windDirection = value % 360.0  # Wrap around 360 degrees
        elif parts[0] == "launch":
            if parts[1] == "inclination":
                launch.inclination = max(0.0, min(90.0, value))  # Clamp inclination
            elif parts[1] == "heading":
                launch.heading = value % 360.0  # Wrap around 360 degrees
            elif parts[1] == "railLength":
                launch.railLength = max(1.0, min(20.0, value))  # Clamp rail length
    
    def _calculate_statistics(self):
        """Calculate statistics from simulation results"""
        successful_results = [r for r in self.results if r and r.simulationFidelity != "failed"]
        
        if not successful_results:
            logger.warning("No successful results for statistics calculation")
            self.statistics = {}
            return
        
        # Extract values for each metric
        metrics = {
            'maxAltitude': [r.maxAltitude for r in successful_results],
            'maxVelocity': [r.maxVelocity for r in successful_results],
            'apogeeTime': [r.apogeeTime for r in successful_results],
            'stabilityMargin': [r.stabilityMargin for r in successful_results]
        }
        
        # Calculate statistics for each metric
        self.statistics = {}
        for metric_name, values in metrics.items():
            if values:
                import numpy as np
                values_array = np.array(values)
                
                self.statistics[metric_name] = MonteCarloStatistics(
                    mean=float(np.mean(values_array)),
                    std=float(np.std(values_array)),
                    min=float(np.min(values_array)),
                    max=float(np.max(values_array)),
                    percentiles={
                        "5": float(np.percentile(values_array, 5)),
                        "25": float(np.percentile(values_array, 25)),
                        "50": float(np.percentile(values_array, 50)),
                        "75": float(np.percentile(values_array, 75)),
                        "95": float(np.percentile(values_array, 95))
                    }
                )
    
    def _calculate_landing_dispersion(self) -> Dict[str, Any]:
        """Calculate landing dispersion from simulation results"""
        successful_results = [r for r in self.results if r and r.simulationFidelity != "failed" and r.driftDistance is not None]
        
        if not successful_results:
            return {
                "coordinates": [[0, 0]],
                "cep": 0.0,
                "majorAxis": 0.0,
                "minorAxis": 0.0,
                "rotation": 0.0,
                "meanDrift": 0.0,
                "maxDrift": 0.0
            }
        
        import numpy as np
        import random
        
        # Generate landing coordinates based on drift distances
        coordinates = []
        drift_distances = []
        
        for result in successful_results:
            # Generate random angle for landing direction
            angle = random.uniform(0, 2 * np.pi)
            drift = result.driftDistance or 0.0
            
            x = drift * np.cos(angle)
            y = drift * np.sin(angle)
            coordinates.append([float(x), float(y)])
            drift_distances.append(drift)
        
        drift_array = np.array(drift_distances)
        
        # Calculate dispersion metrics
        mean_drift = float(np.mean(drift_array))
        max_drift = float(np.max(drift_array))
        cep = float(np.percentile(drift_array, 50))  # Circular Error Probable (50th percentile)
        
        # Estimate ellipse parameters
        major_axis = float(np.percentile(drift_array, 95)) * 2
        minor_axis = float(np.percentile(drift_array, 75)) * 2
        
        return {
            "coordinates": coordinates,
            "cep": cep,
            "majorAxis": major_axis,
            "minorAxis": minor_axis,
            "rotation": 0.0,  # Simplified - assume no preferred direction
            "meanDrift": mean_drift,
            "maxDrift": max_drift
        }
    
    def _extract_summary(self, result: SimulationResult) -> Dict[str, float]:
        """Extract summary data from simulation result"""
        return {
            "maxAltitude": result.maxAltitude,
            "maxVelocity": result.maxVelocity,
            "apogeeTime": result.apogeeTime,
            "stabilityMargin": result.stabilityMargin,
            "driftDistance": result.driftDistance or 0.0
        }
    
    async def _cleanup_progress_tracking(self):
        """Clean up progress tracking after delay"""
        await asyncio.sleep(300)  # Keep progress for 5 minutes
        with progress_lock:
            if self.simulation_id in monte_carlo_progress:
                del monte_carlo_progress[self.simulation_id]

