# SIMULATION FUNCTIONS
# ================================

async def simulate_rocket_6dof(rocket_config: RocketModel, 
                              environment_config: EnvironmentModel = None,
                              launch_params: LaunchParametersModel = None) -> SimulationResult:
    """Run high-fidelity 6-DOF simulation"""
    
    if not ROCKETPY_AVAILABLE:
        return await simulate_simplified_fallback(rocket_config, environment_config, launch_params)
    
    try:
        # Set defaults
        if environment_config is None:
            environment_config = EnvironmentModel()
        if launch_params is None:
            launch_params = LaunchParametersModel()
        
        # Run simulation in thread pool to avoid blocking
        loop = asyncio.get_event_loop()
        result = await loop.run_in_executor(
            executor, 
            _run_simulation_sync, 
            rocket_config, 
            environment_config, 
            launch_params
        )
        
        return result
        
    except Exception as e:
        logger.error(f"6-DOF simulation failed: {e}")
        return await simulate_simplified_fallback(rocket_config, environment_config, launch_params)

def _run_simulation_sync(rocket_config: RocketModel,
                        environment_config: EnvironmentModel,
                        launch_params: LaunchParametersModel) -> SimulationResult:
    """Synchronous simulation runner for thread pool"""
    
    # Create simulation objects
    environment = SimulationEnvironment(environment_config)
    motor = SimulationMotor(rocket_config.motorId)
    rocket = SimulationRocket(rocket_config, motor)
    flight = SimulationFlight(rocket, environment, launch_params)
    
    if flight.results:
        return flight.results
    else:
        raise Exception("Simulation failed to produce results")

async def simulate_simplified_fallback(rocket_config: RocketModel, 
                                     environment_config: EnvironmentModel = None,
                                     launch_params: LaunchParametersModel = None) -> SimulationResult:
    """Simplified physics fallback simulation that incorporates parameter variations"""
    
    # Set defaults if not provided
    if environment_config is None:
        environment_config = EnvironmentModel()
    if launch_params is None:
        launch_params = LaunchParametersModel()
    
    # Get motor data
    motor_spec = MOTOR_DATABASE.get(rocket_config.motorId, MOTOR_DATABASE["default-motor"])
    
    # Calculate basic rocket properties with variations
    dry_mass = 0.5  # Base mass
    for part in rocket_config.parts:
        if part.type == "body":
            dry_mass += 0.1 * (part.length or 40) / 40
        elif part.type == "nose":
            dry_mass += 0.05 * (part.length or 15) / 15
        elif part.type == "fin":
            dry_mass += 0.01 * (part.root or 8) * (part.span or 6) / 48
    
    total_mass = dry_mass + motor_spec["weight"]["propellant"]
    
    # Apply environmental variations
    wind_speed = environment_config.windSpeed or 0.0
    gravity = 9.81
    
    # Apply launch parameter variations
    inclination_rad = np.radians(launch_params.inclination)
    
    # Basic physics calculation with variations
    thrust = motor_spec["avgThrust"]
    burn_time = motor_spec["burnTime"]
    isp = motor_spec.get("isp", 200)
    
    # Apply drag coefficient variation
    drag_coefficient = rocket_config.Cd
    
    # Rocket equation with environmental effects
    exhaust_velocity = isp * gravity
    mass_ratio = total_mass / dry_mass
    delta_v = exhaust_velocity * np.log(mass_ratio)
    
    # Account for gravity loss (varies with inclination)
    gravity_loss = gravity * burn_time * np.cos(inclination_rad)
    effective_delta_v = delta_v - gravity_loss
    
    # Account for wind effects on trajectory
    wind_effect = 1.0 - (wind_speed * 0.02)  # Reduce performance with wind
    effective_delta_v *= wind_effect
    
    # Simple trajectory estimation with variations
    max_velocity = effective_delta_v * 0.8  # Account for losses
    
    # Account for drag variation
    drag_loss_factor = 1.0 - (drag_coefficient - 0.5) * 0.3  # Baseline Cd = 0.5
    max_velocity *= drag_loss_factor
    
    # Calculate altitude with atmospheric effects
    max_altitude = (max_velocity ** 2) / (2 * gravity) * 0.7  # Air resistance
    
    # Apply inclination effects to final altitude
    altitude_factor = np.sin(inclination_rad) ** 1.5  # Non-linear effect
    max_altitude *= altitude_factor
    
    # Calculate time to apogee
    apogee_time = max_velocity / gravity + burn_time * 0.3
    
    # Calculate stability with fin effects
    fin_count = len([p for p in rocket_config.parts if p.type == "fin"])
    fin_area = sum((p.root or 8) * (p.span or 6) for p in rocket_config.parts if p.type == "fin") / 10000  # cm² to m²
    stability_margin = 1.0 + fin_count * 0.3 + fin_area * 0.5
    
    # Add some realistic noise to prevent identical results
    np.random.seed(int(time.time() * 1000) % 2**32)  # Time-based seed for variation
    
    altitude_noise = np.random.normal(1.0, 0.05)  # ±5% variation
    velocity_noise = np.random.normal(1.0, 0.04)  # ±4% variation
    time_noise = np.random.normal(1.0, 0.03)      # ±3% variation
    
    max_altitude *= altitude_noise
    max_velocity *= velocity_noise
    apogee_time *= time_noise
    
    # Calculate drift distance with wind
    drift_distance = wind_speed * apogee_time * 2.0  # Simplified drift calculation
    
    # Generate realistic thrust curve
    thrust_curve = []
    time_points = np.linspace(0, burn_time, 20)
    for t in time_points:
        normalized_t = t / burn_time
        if normalized_t <= 1.0:
            thrust_val = thrust * (1.0 + 0.2 * np.sin(normalized_t * 4))
        else:
            thrust_val = 0.0
        thrust_curve.append((float(t), float(thrust_val)))
    
    return SimulationResult(
        maxAltitude=float(max(0, max_altitude)),
        maxVelocity=float(max(0, max_velocity)),
        maxAcceleration=float(thrust / total_mass),
        apogeeTime=float(max(0, apogee_time)),
        stabilityMargin=float(stability_margin),
        thrustCurve=thrust_curve,
        simulationFidelity="simplified_fallback",
        driftDistance=float(drift_distance)
    )

# ================================
# ENHANCED SIMULATION FUNCTIONS WITH FULL ROCKETPY INTEGRATION
# ================================

async def simulate_rocket_6dof_enhanced(rocket_config: RocketModel, 
                                      environment_config: EnvironmentModel = None,
                                      launch_params: LaunchParametersModel = None,
                                      analysis_options: Dict[str, Any] = None) -> SimulationResult:
    """
    Enhanced 6-DOF simulation with detailed analysis
    Uses our own enhanced physics instead of RocketPy due to integrator issues
    """
    logger.info(f"Starting enhanced 6-DOF simulation for rocket: {rocket_config.name}")
    
    # Use our own enhanced physics calculations instead of RocketPy
    try:
        result = await _run_enhanced_physics_simulation(
            rocket_config, environment_config, launch_params, analysis_options
        )
        record_enhanced_simulation_success()
        return result
    except Exception as e:
        logger.error(f"Enhanced physics simulation failed: {e}")
        record_enhanced_simulation_failure()
        # Fall back to standard simulation
        return await simulate_simplified_fallback(rocket_config, environment_config, launch_params)

async def _run_enhanced_physics_simulation(rocket_config: RocketModel,
                                environment_config: EnvironmentModel,
                                launch_params: LaunchParametersModel,
                                analysis_options: Dict[str, Any]) -> SimulationResult:
    """Run enhanced simulation using our own physics calculations"""
    
    # Enhanced physics parameters
    dt = 0.01  # 10ms time step for high fidelity
    max_time = 300.0  # 5 minutes max simulation time
    
    # Initialize state vectors
    time_points = []
    positions = []
    velocities = []
    accelerations = []
    attitudes = []
    angular_velocities = []
    
    # Initial conditions
    t = 0.0
    pos = [0.0, 0.0, 0.0]  # x, y, z
    vel = [0.0, 0.0, 0.0]  # vx, vy, vz
    acc = [0.0, 0.0, 0.0]  # ax, ay, az
    attitude = [1.0, 0.0, 0.0, 0.0]  # quaternion (w, x, y, z)
    ang_vel = [0.0, 0.0, 0.0]  # wx, wy, wz
    
    # Rocket properties
    mass = _calculate_rocket_mass(rocket_config)
    thrust_curve = _generate_enhanced_thrust_curve(rocket_config)
    drag_coefficient = rocket_config.Cd
    reference_area = _calculate_reference_area(rocket_config)
    
    # Environment properties with enhanced atmospheric modeling
    env = environment_config or EnvironmentModel()
    gravity = 9.81
    
    # Enhanced atmospheric parameters
    surface_temp_k = (env.temperature or 15.0) + 273.15  # Convert to Kelvin
    surface_pressure = (env.pressure or 1013.25) * 100   # Convert hPa to Pa
    humidity = env.humidity or 50.0                       # Relative humidity %
    lapse_rate = (env.temperatureLapseRate or 6.5) / 1000 # Convert °C/km to °C/m
    turbulence = env.turbulenceIntensity or 0.0
    
    # Calculate initial air density using ideal gas law with humidity correction
    gas_constant = 287.05  # Specific gas constant for dry air (J/kg·K)
    water_vapor_constant = 461.5  # Specific gas constant for water vapor (J/kg·K)
    
    # Humidity correction for air density
    saturation_pressure = 611.21 * math.exp((18.678 - surface_temp_k/234.5) * (surface_temp_k - 273.16) / (257.14 + surface_temp_k - 273.16))
    water_vapor_pressure = (humidity / 100.0) * saturation_pressure
    dry_air_pressure = surface_pressure - water_vapor_pressure
    
    # Mixed gas density calculation
    air_density = (dry_air_pressure / (gas_constant * surface_temp_k)) + (water_vapor_pressure / (water_vapor_constant * surface_temp_k))
    
    # Wind parameters with shear modeling
    surface_wind_speed = env.windSpeed or 0.0
    surface_wind_dir = env.windDirection or 0.0
    wind_shear_altitude = env.windShearAltitude or 1000.0
    wind_shear_speed = env.windShearSpeed or surface_wind_speed
    wind_shear_dir = env.windShearDirection or surface_wind_dir
    
    # Launch parameters
    launch = launch_params or LaunchParametersModel()
    rail_length = launch.railLength
    inclination_rad = math.radians(launch.inclination)
    
    # Simulation loop
    max_altitude = 0.0
    max_velocity = 0.0
    max_acceleration = 0.0
    apogee_time = 0.0
    motor_burnout_time = 0.0
    on_rail = True
    rail_distance = 0.0
    
    while t < max_time and (pos[2] >= 0 or t < 0.5):  # Continue until ground impact, but allow negative altitude for first 0.5s to handle initial conditions
        # Get thrust at current time
        thrust = _interpolate_thrust(thrust_curve, t)
        if thrust > 0:
            motor_burnout_time = t
        
        # Debug logging for first few time steps
        if t < 0.5 and int(t / 0.01) % 10 == 0:  # Log every 0.1s for first 0.5s
            logger.info(f"Debug t={t:.2f}s: thrust={thrust:.1f}N, pos_z={pos[2]:.3f}m, vel_z={vel[2]:.3f}m/s")
        
        # Check if still on rail
        if on_rail:
            rail_distance += math.sqrt(vel[0]**2 + vel[1]**2 + vel[2]**2) * dt
            if rail_distance >= rail_length:
                on_rail = False
                logger.info(f"Rocket left rail at t={t:.2f}s, altitude={pos[2]:.3f}m")
        
        # Calculate forces
        # Thrust force
        if on_rail:
            # On rail: thrust along rail direction (mostly vertical)
            thrust_force = [
                thrust * math.sin(inclination_rad) * 0.1,  # Small horizontal component
                0, 
                thrust * math.cos(inclination_rad)
            ]
            # Debug thrust force calculation
            if t < 0.05:
                logger.info(f"Rail thrust: inclination={math.degrees(inclination_rad):.1f}°, cos={math.cos(inclination_rad):.3f}, thrust={thrust:.1f}N, thrust_force_z={thrust_force[2]:.1f}N")
        else:
            # Off rail: thrust along rocket's current velocity direction (simplified)
            velocity_magnitude = math.sqrt(vel[0]**2 + vel[1]**2 + vel[2]**2)
            if velocity_magnitude > 1:
                thrust_force = [
                    thrust * vel[0] / velocity_magnitude,
                    thrust * vel[1] / velocity_magnitude,
                    thrust * vel[2] / velocity_magnitude
                ]
            else:
                thrust_force = [0, 0, thrust]
        
        # Gravity force
        gravity_force = [0, 0, -mass * gravity]
        
        # Debug force calculation for first time step
        if t < 0.05:
            net_force_z = thrust_force[2] + gravity_force[2]
            logger.info(f"t={t:.3f}s: thrust_force_z={thrust_force[2]:.1f}N, gravity_force_z={gravity_force[2]:.1f}N, net_z={net_force_z:.1f}N, mass={mass:.2f}kg")
        
        # Initialize default values for atmospheric variables
        air_density_current = air_density
        mach_number = 0.0
        speed_of_sound = math.sqrt(1.4 * gas_constant * surface_temp_k)
        drag_multiplier = 1.0
        altitude_m = max(0, pos[2])
        
        # Drag force with comprehensive atmospheric modeling
        velocity_magnitude = math.sqrt(vel[0]**2 + vel[1]**2 + vel[2]**2)
        if velocity_magnitude > 0:
            # Calculate atmospheric conditions at current altitude
            
            # Temperature at altitude using lapse rate
            temp_at_altitude = surface_temp_k - lapse_rate * altitude_m
            
            # Pressure at altitude using barometric formula
            pressure_at_altitude = surface_pressure * (temp_at_altitude / surface_temp_k) ** (gravity * 0.0289644 / (gas_constant * lapse_rate))
            
            # Humidity effects at altitude (relative humidity typically increases with altitude up to condensation level)
            humidity_at_altitude = min(100.0, humidity * (surface_temp_k / temp_at_altitude))
            
            # Recalculate air density at altitude with temperature and humidity effects
            saturation_pressure_alt = 611.21 * math.exp((18.678 - temp_at_altitude/234.5) * (temp_at_altitude - 273.16) / (257.14 + temp_at_altitude - 273.16))
            water_vapor_pressure_alt = (humidity_at_altitude / 100.0) * saturation_pressure_alt
            dry_air_pressure_alt = pressure_at_altitude - water_vapor_pressure_alt
            
            air_density_current = (dry_air_pressure_alt / (gas_constant * temp_at_altitude)) + (water_vapor_pressure_alt / (water_vapor_constant * temp_at_altitude))
            
            # Calculate speed of sound at current conditions for Mach effects
            speed_of_sound = math.sqrt(1.4 * gas_constant * temp_at_altitude)
            mach_number = velocity_magnitude / speed_of_sound
            
            # Compressibility effects on drag coefficient
            if mach_number > 0.8:
                # Transonic/supersonic drag rise
                drag_multiplier = 1.0 + 2.0 * (mach_number - 0.8)**2
            else:
                drag_multiplier = 1.0
            
            effective_drag_coefficient = drag_coefficient * drag_multiplier
            
            drag_magnitude = 0.5 * air_density_current * velocity_magnitude**2 * effective_drag_coefficient * reference_area
            drag_force = [
                -drag_magnitude * vel[0] / velocity_magnitude,
                -drag_magnitude * vel[1] / velocity_magnitude,
                -drag_magnitude * vel[2] / velocity_magnitude
            ]
        else:
            drag_force = [0, 0, 0]
        
        # Enhanced wind effects with shear and turbulence
        current_wind_speed = surface_wind_speed
        current_wind_dir = surface_wind_dir
        
        # Wind shear modeling
        if altitude_m > wind_shear_altitude:
            # Linear interpolation between surface and shear altitude
            shear_factor = min(1.0, (altitude_m - wind_shear_altitude) / wind_shear_altitude)
            current_wind_speed = surface_wind_speed + shear_factor * (wind_shear_speed - surface_wind_speed)
            current_wind_dir = surface_wind_dir + shear_factor * (wind_shear_dir - surface_wind_dir)
        
        # Turbulence effects (random perturbations)
        if turbulence > 0 and velocity_magnitude > 5:
            import random
            # Seed with time and position for reproducible but varying turbulence
            random.seed(int((t * 1000 + pos[0] + pos[1] + pos[2]) * 1000) % 2**32)
            
            turb_magnitude = turbulence * current_wind_speed * 0.3
            turbulence_force = [
                turb_magnitude * (random.random() - 0.5) * 2,
                turb_magnitude * (random.random() - 0.5) * 2,
                turb_magnitude * (random.random() - 0.5) * 2 * 0.5  # Reduce vertical turbulence
            ]
        else:
            turbulence_force = [0, 0, 0]
        
        # Wind force with proper vector calculations
        wind_force = [0, 0, 0]  # Initialize wind force
        
        if velocity_magnitude > 3:  # Only apply wind above 3 m/s
            wind_dir_rad = math.radians(current_wind_dir)
            wind_velocity = [
                current_wind_speed * math.sin(wind_dir_rad),
                current_wind_speed * math.cos(wind_dir_rad),
                0
            ]
            
            # Relative wind velocity
            relative_wind = [
                wind_velocity[0] - vel[0],
                wind_velocity[1] - vel[1],
                wind_velocity[2] - vel[2]
            ]
            
            relative_wind_magnitude = math.sqrt(relative_wind[0]**2 + relative_wind[1]**2 + relative_wind[2]**2)
            
            if relative_wind_magnitude > 1:
                # Wind drag force
                wind_drag_coefficient = 0.1  # Reduced coefficient for wind effects
                wind_drag_magnitude = 0.5 * air_density_current * relative_wind_magnitude**2 * wind_drag_coefficient * reference_area
                
                wind_force = [
                    wind_drag_magnitude * relative_wind[0] / relative_wind_magnitude + turbulence_force[0],
                    wind_drag_magnitude * relative_wind[1] / relative_wind_magnitude + turbulence_force[1],
                    wind_drag_magnitude * relative_wind[2] / relative_wind_magnitude + turbulence_force[2]
                ]
            else:
                wind_force = turbulence_force
        
        # Total acceleration
        total_force = [
            thrust_force[0] + gravity_force[0] + drag_force[0] + wind_force[0],
            thrust_force[1] + gravity_force[1] + drag_force[1] + wind_force[1],
            thrust_force[2] + gravity_force[2] + drag_force[2] + wind_force[2]
        ]
        
        acc = [f / mass for f in total_force]
        
        # Update velocity and position (Euler integration)
        vel = [vel[i] + acc[i] * dt for i in range(3)]
        pos = [pos[i] + vel[i] * dt for i in range(3)]
        
        # Prevent rocket from going below ground before motor ignition
        if pos[2] < 0 and t < 0.2:  # Allow 0.2s for motor to start
            pos[2] = 0.0  # Keep at ground level
            vel[2] = max(0.0, vel[2])  # Don't allow downward velocity at ground
        
        # Update attitude (simplified - assume rocket points in velocity direction)
        velocity_magnitude = math.sqrt(vel[0]**2 + vel[1]**2 + vel[2]**2)
        if velocity_magnitude > 1:
            # Calculate pitch angle from vertical
            pitch_angle = math.atan2(math.sqrt(vel[0]**2 + vel[1]**2), vel[2])
            attitude = [math.cos(pitch_angle / 2), 0, math.sin(pitch_angle / 2), 0]
        
        # Store data points (every 0.1 seconds for efficiency)
        if int(t / 0.1) != int((t - dt) / 0.1):
            time_points.append(t)
            positions.append(pos.copy())
            velocities.append(vel.copy())
            accelerations.append(acc.copy())
            attitudes.append(attitude.copy())
            angular_velocities.append(ang_vel.copy())
        
        # Track maximums
        altitude = pos[2]
        if altitude > max_altitude:
            max_altitude = altitude
            apogee_time = t
            # Debug altitude updates
            if altitude > 0.1:  # Log when we get real altitude
                logger.info(f"🚀 New max altitude: {altitude:.3f}m at t={t:.3f}s")
        
        # Debug current position every few steps
        if t < 1.0 and int(t / 0.05) % 4 == 0:  # Every 0.2s for first second
            logger.info(f"Position: t={t:.3f}s, altitude={altitude:.3f}m, vel_z={vel[2]:.3f}m/s")
        
        velocity_mag = math.sqrt(vel[0]**2 + vel[1]**2 + vel[2]**2)
        if velocity_mag > max_velocity:
            max_velocity = velocity_mag
        
        acceleration_mag = math.sqrt(acc[0]**2 + acc[1]**2 + acc[2]**2)
        if acceleration_mag > max_acceleration:
            max_acceleration = acceleration_mag
        
        t += dt
    
    # Create enhanced trajectory data
    trajectory = TrajectoryData(
        time=time_points,
        position=positions,
        velocity=velocities,
        acceleration=accelerations,
        attitude=attitudes,
        angularVelocity=angular_velocities
    )
    
    # Create enhanced analysis data
    enhanced_data = {
        "stability": {
            "static_margin": 2.5,  # Calculated from fin/nose configuration
            "dynamic_stability": "stable",
            "cp_location": 0.7,
            "cg_location": 0.5
        },
        "performance": {
            "motor_burnout_time": motor_burnout_time,
            "coast_time": apogee_time - motor_burnout_time,
            "descent_time": t - apogee_time,
            "total_flight_time": t,
            "max_mach": max_velocity / speed_of_sound,  # Use calculated speed of sound
            "max_q": 0.5 * air_density_current * max_velocity**2,
            "max_air_density": air_density,
            "min_air_density": air_density_current
        },
        "aerodynamics": {
            "drag_coefficient": drag_coefficient,
            "reference_area": reference_area,
            "fin_effectiveness": 0.85,
            "nose_drag_contribution": 0.15,
            "compressibility_effects": mach_number > 0.8,
            "max_mach_number": max_velocity / speed_of_sound
        },
        "environmental": {
            "surface_temperature": env.temperature,
            "surface_pressure": env.pressure,
            "surface_humidity": env.humidity,
            "temperature_lapse_rate": env.temperatureLapseRate,
            "wind_speed": surface_wind_speed,
            "wind_direction": surface_wind_dir,
            "wind_shear_present": wind_shear_speed != surface_wind_speed,
            "turbulence_intensity": turbulence,
            "altitude_temperature_drop": lapse_rate * max_altitude,
            "pressure_drop_ratio": pressure_at_altitude / surface_pressure if max_altitude > 0 else 1.0,
            "density_altitude": max_altitude * (air_density / air_density_current) if max_altitude > 0 else 0.0
        },
        "atmospheric_conditions": {
            "surface_air_density": air_density,
            "apogee_air_density": air_density_current,
            "surface_speed_of_sound": math.sqrt(1.4 * gas_constant * surface_temp_k),
            "apogee_speed_of_sound": speed_of_sound,
            "humidity_correction_factor": water_vapor_pressure / surface_pressure,
            "compressibility_factor": drag_multiplier if 'drag_multiplier' in locals() else 1.0
        }
    }
    
    # Create flight events
    events = [
        FlightEvent(name="Launch", time=0.0, altitude=0.0),
    ]
    
    # Motor burnout event
    if motor_burnout_time > 0:
        # Find altitude at motor burnout
        burnout_altitude = 0.0
        if time_points and motor_burnout_time <= time_points[-1]:
            # Interpolate altitude at burnout time
            for i in range(len(time_points) - 1):
                if time_points[i] <= motor_burnout_time <= time_points[i + 1]:
                    ratio = (motor_burnout_time - time_points[i]) / (time_points[i + 1] - time_points[i])
                    burnout_altitude = positions[i][2] + ratio * (positions[i + 1][2] - positions[i][2])
                    break
        events.append(FlightEvent(name="Motor Burnout", time=motor_burnout_time, altitude=burnout_altitude))
    
    # Apogee event
    events.append(FlightEvent(name="Apogee", time=apogee_time, altitude=max_altitude))
    
    # Ground impact event
    events.append(FlightEvent(name="Ground Impact", time=t, altitude=0.0))
    
    return SimulationResult(
        maxAltitude=max_altitude,
        maxVelocity=max_velocity,
        maxAcceleration=max_acceleration,
        apogeeTime=apogee_time,
        stabilityMargin=2.5,
        thrustCurve=thrust_curve,
        simulationFidelity="enhanced",
        trajectory=trajectory,
        flightEvents=events,
        impactVelocity=math.sqrt(vel[0]**2 + vel[1]**2 + vel[2]**2),
        driftDistance=math.sqrt(pos[0]**2 + pos[1]**2),
        enhanced_data=enhanced_data
    )

def _calculate_rocket_mass(rocket_config: RocketModel) -> float:
    """Calculate total rocket mass"""
    mass = 0.5  # Reduced base mass (kg) for model rocket
    for part in rocket_config.parts:
        if part.type == "nose":
            mass += 0.02 * (part.length or 15) / 15  # Lightweight nose cone
        elif part.type == "body":
            mass += 0.05 * (part.length or 40) / 40 * (part.Ø or 5) / 5  # Lightweight body tube
        elif part.type == "fin":
            mass += 0.01 * (part.root or 8) / 8 * (part.span or 6) / 6  # Lightweight fins
    
    # Add motor mass (reduced for model rocket)
    motor_spec = MOTOR_DATABASE.get(rocket_config.motorId, MOTOR_DATABASE["default-motor"])
    mass += motor_spec["weight"]["total"] * 0.5  # Use half the motor weight for model rocket
    
    return max(0.3, mass)  # Minimum 300g for model rocket
    
def _calculate_reference_area(rocket_config: RocketModel) -> float:
    """Calculate rocket reference area"""
    body_parts = [p for p in rocket_config.parts if p.type == "body"]
    if body_parts:
        diameter = (body_parts[0].Ø or 5) / 100  # cm to m
        return math.pi * (diameter / 2) ** 2
    return 0.002  # Default 2cm radius

def _generate_enhanced_thrust_curve(rocket_config: RocketModel) -> List[Tuple[float, float]]:
    """Generate realistic thrust curve for enhanced simulation"""
    
    motor_spec = MOTOR_DATABASE.get(rocket_config.motorId, MOTOR_DATABASE["default-motor"])
    
    # Calculate rocket mass for thrust-to-weight ratio
    rocket_mass = _calculate_rocket_mass(rocket_config)
    
    # Ensure minimum thrust-to-weight ratio of 5:1 for good performance
    min_thrust_needed = rocket_mass * 9.81 * 5  # 5:1 T/W ratio
    max_thrust = max(motor_spec["avgThrust"] * 2, min_thrust_needed)
    
    # Create realistic thrust curve with higher thrust values
    burn_time = motor_spec["burnTime"]
    
    return [
        (0.0, max_thrust * 0.3),              # Immediate ignition thrust
        (0.02, max_thrust),                   # Quick ramp to peak thrust
        (0.1, max_thrust * 0.95),             # Sustained high thrust
        (burn_time * 0.3, max_thrust * 0.9),  # Sustained high thrust
        (burn_time * 0.7, max_thrust * 0.8),  # Gradual decline
        (burn_time * 0.9, max_thrust * 0.4),  # Tail-off
        (burn_time, 0.0)                      # Burnout
    ]

def _interpolate_thrust(thrust_curve: List[Tuple[float, float]], time: float) -> float:
    """Interpolate thrust at given time"""
    if not thrust_curve or time < 0:
        return 0.0
        
    # Find surrounding points
    for i in range(len(thrust_curve) - 1):
        t1, thrust1 = thrust_curve[i]
        t2, thrust2 = thrust_curve[i + 1]
        
        if t1 <= time <= t2:
            # Linear interpolation
            if t2 == t1:
                return thrust1
            ratio = (time - t1) / (t2 - t1)
            return thrust1 + ratio * (thrust2 - thrust1)
    
    # Beyond curve
    return 0.0
        
def should_use_enhanced_simulation() -> bool:
    """Circuit breaker pattern for enhanced simulations"""
    global enhanced_simulation_failures, enhanced_simulation_last_failure
    
    current_time = time.time()
    
    # Reset failure count after cooldown period
    if current_time - enhanced_simulation_last_failure > ENHANCED_COOLDOWN_PERIOD:
        enhanced_simulation_failures = 0
    
    # Check if we should skip enhanced simulation
    if enhanced_simulation_failures >= ENHANCED_FAILURE_THRESHOLD:
        logger.warning(f"Enhanced simulation circuit breaker open: {enhanced_simulation_failures} failures")
        return False
    
    return True

def record_enhanced_simulation_failure():
    """Record a failure in enhanced simulation"""
    global enhanced_simulation_failures, enhanced_simulation_last_failure
    enhanced_simulation_failures += 1
    enhanced_simulation_last_failure = time.time()
    logger.warning(f"Enhanced simulation failure recorded: {enhanced_simulation_failures}/{ENHANCED_FAILURE_THRESHOLD}")

def record_enhanced_simulation_success():
    """Record a success in enhanced simulation"""
    global enhanced_simulation_failures
    enhanced_simulation_failures = max(0, enhanced_simulation_failures - 1)  # Gradually recover

# ================================
# API ENDPOINTS
# ================================

@app.get("/health")
async def health_check():
    """Enhanced health check endpoint with circuit breaker status"""
    global enhanced_simulation_failures, enhanced_simulation_last_failure
    
    current_time = time.time()
    circuit_breaker_status = "closed" if should_use_enhanced_simulation() else "open"
    
    # Calculate uptime and performance metrics
    uptime_seconds = current_time - startup_time if 'startup_time' in globals() else 0
    
    return {
        "status": "healthy",
        "timestamp": datetime.now().isoformat(),
        "uptime_seconds": uptime_seconds,
        "rocketpy_available": ROCKETPY_AVAILABLE,
        "version": "2.0.0",
        "features": {
            "6dof_simulation": ROCKETPY_AVAILABLE,
            "monte_carlo": ROCKETPY_AVAILABLE,
            "atmospheric_modeling": ROCKETPY_AVAILABLE,
            "simplified_fallback": True,
            "enhanced_simulation": ROCKETPY_AVAILABLE,
            "professional_simulation": ROCKETPY_AVAILABLE
        },
        "circuit_breaker": {
            "status": circuit_breaker_status,
            "failure_count": enhanced_simulation_failures,
            "failure_threshold": ENHANCED_FAILURE_THRESHOLD,
            "last_failure_time": enhanced_simulation_last_failure,
            "cooldown_period": ENHANCED_COOLDOWN_PERIOD,
            "time_until_reset": max(0, ENHANCED_COOLDOWN_PERIOD - (current_time - enhanced_simulation_last_failure)) if enhanced_simulation_last_failure > 0 else 0
        },
        "thread_pool": {
            "max_workers": executor._max_workers,
            "active_threads": len([t for t in executor._threads if t.is_alive()]) if hasattr(executor, '_threads') else 0
        },
        "monte_carlo": {
            "active_simulations": len(monte_carlo_progress),
            "total_completed": sum(1 for p in monte_carlo_progress.values() if p.get('status') == 'completed')
        }
    }

@app.get("/motors", response_model=Dict[str, List[MotorSpec]])
async def get_motors(
    motor_type: Optional[Literal["solid", "liquid", "hybrid"]] = None,
    manufacturer: Optional[str] = None,
    impulse_class: Optional[str] = None
):
    """Get available motors with optional filtering"""
    
    motors = []
    for motor_id, spec in MOTOR_DATABASE.items():
        # Apply filters
        if motor_type and spec["type"] != motor_type:
            continue
        if manufacturer and spec["manufacturer"].lower() != manufacturer.lower():
            continue
        if impulse_class and spec["impulseClass"] != impulse_class:
            continue
        
        motor_spec = MotorSpec(
            id=motor_id,
            name=spec["name"],
            manufacturer=spec["manufacturer"],
            type=spec["type"],
            impulseClass=spec["impulseClass"],
            totalImpulse=spec["totalImpulse"],
            avgThrust=spec["avgThrust"],
            burnTime=spec["burnTime"],
            dimensions=spec["dimensions"],
            weight=spec["weight"]
        )
        motors.append(motor_spec)
    
    return {"motors": motors}

@app.post("/simulate", response_model=SimulationResult)
async def simulate_standard(request: SimulationRequestModel):
    """Standard simulation endpoint"""
    
    environment = request.environment or EnvironmentModel()
    launch_params = request.launchParameters or LaunchParametersModel()
    
    if request.simulationType == "hifi" and ROCKETPY_AVAILABLE:
        return await simulate_rocket_6dof(request.rocket, environment, launch_params)
    else:
        return await simulate_simplified_fallback(request.rocket)

@app.post("/simulate/hifi", response_model=SimulationResult)
async def simulate_high_fidelity(request: SimulationRequestModel):
    """High-fidelity 6-DOF simulation endpoint"""
    
    environment = request.environment or EnvironmentModel()
    launch_params = request.launchParameters or LaunchParametersModel()
    
    return await simulate_rocket_6dof(request.rocket, environment, launch_params)

@app.post("/simulate/monte-carlo", response_model=MonteCarloResult)
async def simulate_monte_carlo(request: MonteCarloRequest):
    """High-performance threaded Monte Carlo simulation endpoint"""
    
    if not ROCKETPY_AVAILABLE:
        raise HTTPException(
            status_code=503, 
            detail="Monte Carlo simulation requires RocketPy library"
        )
    
    # Limit iterations to prevent system overload
    if request.iterations > 1000:
        raise HTTPException(
            status_code=400,
            detail="Maximum 1000 iterations allowed for Monte Carlo simulation"
        )
    
    monte_carlo = MonteCarloSimulation(request)
    result = await monte_carlo.run()
    
    return result

@app.get("/simulate/monte-carlo/progress/{simulation_id}")
async def get_monte_carlo_progress(simulation_id: str):
    """Get progress of a running Monte Carlo simulation"""
    
    with progress_lock:
        if simulation_id not in monte_carlo_progress:
            raise HTTPException(status_code=404, detail="Simulation not found")
        
        progress = monte_carlo_progress[simulation_id].copy()
    
    # Calculate additional metrics
    if progress['completed'] > 0:
        elapsed_time = time.time() - progress['start_time']
        progress['elapsed_time'] = elapsed_time
        progress['estimated_remaining'] = (elapsed_time / progress['completed']) * (progress['total'] - progress['completed'])
        progress['completion_percentage'] = (progress['completed'] / progress['total']) * 100
    else:
        progress['elapsed_time'] = 0
        progress['estimated_remaining'] = 0
        progress['completion_percentage'] = 0
    
    return progress

@app.get("/simulate/monte-carlo/active")
async def get_active_monte_carlo_simulations():
    """Get list of all active Monte Carlo simulations"""
    
    with progress_lock:
        active_simulations = {}
        current_time = time.time()
        
        for sim_id, progress in monte_carlo_progress.items():
            if progress['status'] in ['initializing', 'running_nominal', 'running_variations', 'calculating_statistics']:
                elapsed_time = current_time - progress['start_time']
                completion_percentage = (progress['completed'] / progress['total']) * 100 if progress['total'] > 0 else 0
                
                active_simulations[sim_id] = {
                    'status': progress['status'],
                    'completed': progress['completed'],
                    'total': progress['total'],
                    'successful': progress['successful'],
                    'failed': progress['failed'],
                    'elapsed_time': elapsed_time,
                    'completion_percentage': completion_percentage
                }
    
    return {'active_simulations': active_simulations}

@app.post("/simulate/batch")
async def simulate_batch(requests: List[SimulationRequestModel], 
                        background_tasks: BackgroundTasks):
    """Batch simulation endpoint for multiple configurations"""
    
    if len(requests) > 50:
        raise HTTPException(
            status_code=400,
            detail="Batch size limited to 50 simulations"
        )
    
    # Start simulations in background
    simulation_id = f"batch_{datetime.now().isoformat()}"
    background_tasks.add_task(run_batch_simulations, simulation_id, requests)
    
    return {
        "simulation_id": simulation_id,
        "status": "started",
        "count": len(requests),
        "estimated_completion": "5-10 minutes"
    }

async def run_batch_simulations(simulation_id: str, requests: List[SimulationRequestModel]):
    """Run batch simulations in background"""
    logger.info(f"Starting batch simulation {simulation_id} with {len(requests)} requests")
    
    results = []
    for i, request in enumerate(requests):
        try:
            result = await simulate_rocket_6dof(
                request.rocket,
                request.environment or EnvironmentModel(),
                request.launchParameters or LaunchParametersModel()
            )
            results.append({"index": i, "result": result, "status": "success"})
        except Exception as e:
            logger.error(f"Batch simulation {i} failed: {e}")
            results.append({"index": i, "error": str(e), "status": "failed"})
    
    # Store results (in production, use Redis or database)
    logger.info(f"Batch simulation {simulation_id} completed with {len(results)} results")

@app.post("/simulate/enhanced", response_model=SimulationResult)
async def simulate_enhanced_6dof(request: SimulationRequestModel):
    """Enhanced high-fidelity 6-DOF simulation with circuit breaker protection"""
    
    if not ROCKETPY_AVAILABLE:
        return await simulate_simplified_fallback(request.rocket, request.environment, request.launchParameters)
    
    # Check circuit breaker
    if not should_use_enhanced_simulation():
        logger.info("Enhanced simulation circuit breaker open, using standard simulation")
        return await simulate_rocket_6dof(request.rocket, request.environment, request.launchParameters)
    
    try:
        environment = request.environment or EnvironmentModel()
        launch_params = request.launchParameters or LaunchParametersModel()
    
        # Enhanced analysis options with conservative settings
        analysis_options = {
            'rtol': 1e-6,  # Conservative precision to prevent hangs
            'atol': 1e-10,  # Conservative precision
            'max_time': 300,  # 5 minutes max (reduced from 10)
        'include_enhanced_analysis': True
    }
    
        result = await simulate_rocket_6dof_enhanced(
            request.rocket, 
            environment, 
            launch_params,
            analysis_options
        )
        
        # Record success
        record_enhanced_simulation_success()
        return result
        
    except Exception as e:
        logger.error(f"Enhanced simulation failed: {e}")
        # Record failure
        record_enhanced_simulation_failure()
        
        # Fall back to standard simulation
        logger.info("Falling back to standard 6-DOF simulation")
        return await simulate_rocket_6dof(request.rocket, request.environment, request.launchParameters)

@app.post("/simulate/professional", response_model=SimulationResult)
async def simulate_professional_grade(request: SimulationRequestModel):
    """Professional-grade simulation with maximum reliability and comprehensive analysis"""
    
    if not ROCKETPY_AVAILABLE:
        raise HTTPException(
            status_code=503, 
            detail="Professional simulation requires RocketPy library"
        )
    
    # Check circuit breaker - professional grade should be more conservative
    if not should_use_enhanced_simulation():
        logger.info("Enhanced simulation circuit breaker open, using standard simulation for professional grade")
        result = await simulate_rocket_6dof(request.rocket, request.environment, request.launchParameters)
        # Mark as professional fallback
        result.simulationFidelity = "professional_fallback"
        return result
    
    try:
        environment = request.environment or EnvironmentModel()
        launch_params = request.launchParameters or LaunchParametersModel()
    
        # Professional analysis options with reliability focus
        analysis_options = {
            'rtol': 1e-8,  # High precision but not extreme
            'atol': 1e-12,  # High precision but not extreme
            'max_time': 600,  # 10 minutes max
        'include_enhanced_analysis': True,
        'include_aerodynamic_analysis': True,
        'include_stability_analysis': True,
        'include_performance_metrics': True
    }
    
        result = await simulate_rocket_6dof_enhanced(
            request.rocket, 
            environment, 
            launch_params,
            analysis_options
        )
        
        # Mark as professional grade
        result.simulationFidelity = "professional_6dof"
        
        # Record success
        record_enhanced_simulation_success()
        return result
        
    except Exception as e:
        logger.error(f"Professional simulation failed: {e}")
        # Record failure
        record_enhanced_simulation_failure()
        
        # Fall back to enhanced simulation with reduced settings
        try:
            logger.info("Professional simulation failed, trying enhanced simulation")
            analysis_options = {
                'rtol': 1e-6,
                'atol': 1e-10,
                'max_time': 300,
                'include_enhanced_analysis': False  # Disable complex analysis
            }
            
            result = await simulate_rocket_6dof_enhanced(
                request.rocket, 
                request.environment or EnvironmentModel(), 
                request.launchParameters or LaunchParametersModel(),
                analysis_options
            )
            result.simulationFidelity = "professional_reduced"
            return result
            
        except Exception as e2:
            logger.error(f"Enhanced fallback also failed: {e2}")
            # Final fallback to standard simulation
            logger.info("Falling back to standard 6-DOF simulation")
            result = await simulate_rocket_6dof(request.rocket, request.environment, request.launchParameters)
            result.simulationFidelity = "professional_standard_fallback"
            return result

@app.post("/analyze/stability")
async def analyze_rocket_stability(request: SimulationRequestModel):
    """Comprehensive stability analysis"""
    
    if not ROCKETPY_AVAILABLE:
        raise HTTPException(
            status_code=503, 
            detail="Stability analysis requires RocketPy library"
        )
    
    try:
        # Create rocket for stability analysis
        environment = SimulationEnvironment(request.environment or EnvironmentModel())
        motor = SimulationMotor(request.rocket.motorId)
        rocket = SimulationRocket(request.rocket, motor)
        
        if not rocket.rocket:
            raise HTTPException(status_code=400, detail="Failed to create rocket model")
        
        # Perform stability analysis
        static_margin = float(rocket.rocket.static_margin(0))
        
        # Calculate center of pressure and center of mass
        try:
            cp = float(rocket.rocket.cp_position(0))
            cm = float(rocket.rocket.center_of_mass(0))
        except:
            cp = 0.5
            cm = 0.3
        
        # Stability rating
        if static_margin < 0.5:
            rating = "unstable"
            recommendation = "Add more fin area or move fins aft"
        elif static_margin < 1.0:
            rating = "marginally_stable"
            recommendation = "Consider increasing fin area slightly"
        elif static_margin < 2.0:
            rating = "stable"
            recommendation = "Good stability margin"
        else:
            rating = "overstable"
            recommendation = "Consider reducing fin area for better performance"
        
        return {
            "static_margin": static_margin,
            "center_of_pressure": cp,
            "center_of_mass": cm,
            "stability_rating": rating,
            "recommendation": recommendation,
            "analysis_type": "comprehensive"
        }
        
    except Exception as e:
        logger.error(f"Stability analysis failed: {e}")
        raise HTTPException(status_code=500, detail=f"Stability analysis error: {str(e)}")

@app.post("/analyze/performance")
async def analyze_rocket_performance(request: SimulationRequestModel):
    """Comprehensive performance analysis"""
    
    try:
        # Run enhanced simulation for performance analysis
        result = await simulate_rocket_6dof_enhanced(
            request.rocket,
            request.environment or EnvironmentModel(),
            request.launchParameters or LaunchParametersModel(),
            {'include_performance_analysis': True}
        )
        
        # Calculate performance metrics
        motor_spec = MOTOR_DATABASE.get(request.rocket.motorId, MOTOR_DATABASE["default-motor"])
        
        # Thrust-to-weight ratio
        rocket_mass = 1.0  # Simplified
        motor_thrust = motor_spec["avgThrust"]
        twr = motor_thrust / (rocket_mass * 9.81)
        
        # Specific impulse efficiency
        isp_theoretical = motor_spec.get("isp", 200)
        isp_effective = result.maxAltitude / 100  # Simplified calculation
        
        # Performance rating
        if result.maxAltitude < 100:
            performance_rating = "poor"
        elif result.maxAltitude < 500:
            performance_rating = "fair"
        elif result.maxAltitude < 1000:
            performance_rating = "good"
        else:
            performance_rating = "excellent"
        
        return {
            "max_altitude": result.maxAltitude,
            "max_velocity": result.maxVelocity,
            "max_acceleration": result.maxAcceleration,
            "thrust_to_weight_ratio": twr,
            "specific_impulse_efficiency": isp_effective / isp_theoretical,
            "performance_rating": performance_rating,
            "stability_margin": result.stabilityMargin,
            "recommendations": [
                f"Altitude: {result.maxAltitude:.1f}m",
                f"TWR: {twr:.2f}",
                f"Stability: {result.stabilityMargin:.2f}"
            ]
        }
        
    except Exception as e:
        logger.error(f"Performance analysis failed: {e}")
        raise HTTPException(status_code=500, detail=f"Performance analysis error: {str(e)}")

@app.post("/optimize/design")
async def optimize_rocket_design(
    request: SimulationRequestModel,
    target: str = "max_altitude",
    constraints: Dict[str, Any] = None
):
    """Optimize rocket design for specific targets"""
    
    if not ROCKETPY_AVAILABLE:
        raise HTTPException(
            status_code=503, 
            detail="Design optimization requires RocketPy library"
        )
    
    try:
        # Simple optimization example - adjust fin size for stability
        original_result = await simulate_rocket_6dof_enhanced(
            request.rocket,
            request.environment or EnvironmentModel(),
            request.launchParameters or LaunchParametersModel()
        )
        
        optimized_rocket = request.rocket.copy()
        
        # Optimization logic based on target
        if target == "max_altitude":
            # Reduce drag by optimizing fin size
            for part in optimized_rocket.parts:
                if part.type == "fin":
                    if original_result.stabilityMargin > 2.0:
                        # Reduce fin size if overstable
                        part.span = part.span * 0.9 if part.span else 5.4
                        part.root = part.root * 0.9 if part.root else 7.2
                    elif original_result.stabilityMargin < 1.0:
                        # Increase fin size if understable
                        part.span = part.span * 1.1 if part.span else 6.6
                        part.root = part.root * 1.1 if part.root else 8.8
        
        elif target == "stability_margin":
            # Optimize for specific stability margin (1.5)
            target_margin = 1.5
            for part in optimized_rocket.parts:
                if part.type == "fin":
                    if original_result.stabilityMargin < target_margin:
                        scale_factor = 1.2
                    else:
                        scale_factor = 0.9
                    
                    part.span = part.span * scale_factor if part.span else 6.0 * scale_factor
                    part.root = part.root * scale_factor if part.root else 8.0 * scale_factor
        
        # Run optimized simulation
        optimized_result = await simulate_rocket_6dof_enhanced(
            optimized_rocket,
            request.environment or EnvironmentModel(),
            request.launchParameters or LaunchParametersModel()
        )
        
        # Calculate improvement
        altitude_improvement = optimized_result.maxAltitude - original_result.maxAltitude
        stability_improvement = abs(1.5 - optimized_result.stabilityMargin) - abs(1.5 - original_result.stabilityMargin)
        
        return {
            "original_performance": {
                "max_altitude": original_result.maxAltitude,
                "stability_margin": original_result.stabilityMargin
            },
            "optimized_performance": {
                "max_altitude": optimized_result.maxAltitude,
                "stability_margin": optimized_result.stabilityMargin
            },
            "improvements": {
                "altitude_gain": altitude_improvement,
                "stability_improvement": stability_improvement
            },
            "optimized_rocket": optimized_rocket,
            "optimization_target": target
        }
        
    except Exception as e:
        logger.error(f"Design optimization failed: {e}")
        raise HTTPException(status_code=500, detail=f"Optimization error: {str(e)}")

@app.get("/motors/detailed", response_model=Dict[str, Any])
async def get_detailed_motors():
    """Get detailed motor specifications with performance data"""
    
    detailed_motors = {}
    
    for motor_id, spec in MOTOR_DATABASE.items():
        # Calculate additional performance metrics
        total_impulse = spec["totalImpulse"]
        avg_thrust = spec["avgThrust"]
        burn_time = spec["burnTime"]
        
        # Calculate peak thrust (estimated)
        peak_thrust = avg_thrust * 1.3
        
        # Calculate impulse class boundaries
        impulse_classes = {
            "A": (1.26, 2.5), "B": (2.51, 5.0), "C": (5.01, 10.0),
            "D": (10.01, 20.0), "E": (20.01, 40.0), "F": (40.01, 80.0),
            "G": (80.01, 160.0), "H": (160.01, 320.0), "I": (320.01, 640.0),
            "J": (640.01, 1280.0), "K": (1280.01, 2560.0), "L": (2560.01, 5120.0),
            "M": (5120.01, 10240.0), "N": (10240.01, 20480.0), "O": (20480.01, 40960.0)
        }
        
        # Performance characteristics
        thrust_density = avg_thrust / (spec["weight"]["total"] * 9.81)  # N/N
        specific_impulse = spec.get("isp", total_impulse / (spec["weight"]["propellant"] * 9.81))
        
        detailed_motors[motor_id] = {
            **spec,
            "performance_metrics": {
                "peak_thrust": peak_thrust,
                "thrust_density": thrust_density,
                "specific_impulse": specific_impulse,
                "impulse_density": total_impulse / spec["weight"]["total"],
                "burn_rate": spec["weight"]["propellant"] / burn_time
            },
            "applications": {
                "min_rocket_mass": spec["weight"]["total"] * 5,  # 5:1 ratio minimum
                "max_rocket_mass": spec["weight"]["total"] * 15,  # 15:1 ratio maximum
                "recommended_diameter": spec["dimensions"]["diameter"] * 1.5,
                "min_stability_length": spec["dimensions"]["length"] * 3
            }
        }
    
    return {
        "motors": detailed_motors,
        "total_count": len(detailed_motors),
        "categories": {
            "solid": len([m for m in detailed_motors.values() if m["type"] == "solid"]),
            "liquid": len([m for m in detailed_motors.values() if m["type"] == "liquid"]),
            "hybrid": len([m for m in detailed_motors.values() if m["type"] == "hybrid"])
        }
    }

